{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "node",
  "include-v-in-tag": true,
  "include-component-in-tag": false,
  "separate-pull-requests": false,
  "bump-minor-pre-major": true,
  "bump-patch-for-minor-pre-major": true,
  "extra-files": [
    {
      "type": "json",
      "path": "jsr.json",
      "jsonpath": "$.version"
    },
    {
      "type": "json",
      "path": "packages/auth/package.json",
      "jsonpath": "$.version"
    },
    {
      "type": "json",
      "path": "packages/cache/package.json",
      "jsonpath": "$.version"
    },
    {
      "type": "json",
      "path": "packages/config/package.json",
      "jsonpath": "$.version"
    },
    {
      "type": "json",
      "path": "packages/console/package.json",
      "jsonpath": "$.version"
    },
    {
      "type": "json",
      "path": "packages/container/package.json",
      "jsonpath": "$.version"
    },
    {
      "type": "json",
      "path": "packages/filesystem/package.json",
      "jsonpath": "$.version"
    },
    {
      "type": "json",
      "path": "packages/foundation/package.json",
      "jsonpath": "$.version"
    },
    {
      "type": "json",
      "path": "packages/http/package.json",
      "jsonpath": "$.version"
    },
    {
      "type": "json",
      "path": "packages/logger/package.json",
      "jsonpath": "$.version"
    },
    {
      "type": "json",
      "path": "packages/middleware/package.json",
      "jsonpath": "$.version"
    },
    {
      "type": "json",
      "path": "packages/orm/package.json",
      "jsonpath": "$.version"
    },
    {
      "type": "json",
      "path": "packages/routing/package.json",
      "jsonpath": "$.version"
    },
    {
      "type": "json",
      "path": "packages/session/package.json",
      "jsonpath": "$.version"
    },
    {
      "type": "json",
      "path": "packages/support/package.json",
      "jsonpath": "$.version"
    },
    {
      "type": "json",
      "path": "packages/validation/package.json",
      "jsonpath": "$.version"
    },
    {
      "type": "json",
      "path": "packages/websocket/package.json",
      "jsonpath": "$.version"
    }
  ],
  "packages": {
    ".": {
      "component": "framework",
      "package-name": "@ninots/framework",
      "changelog-path": "CHANGELOG.md"
    }
