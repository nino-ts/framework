{
  "entryPointStrategy": "packages",
  "entryPoints": [
    "packages/*"
  ],
  "out": "docs",
  "exclude": [
    "**/*.test.ts",
    "**/*.legacy.ts",
    "**/tests/**"
  ],
  "excludePrivate": true,
  "excludeProtected": false,
  "excludeExternals": true,
  "categorizeByGroup": true,
  "defaultCategory": "API",
  "categoryOrder": [
    "Container",
    "HTTP",
    "Routing",
    "Middleware",
    "Foundation",
    "Console",
    "ORM"
  ],
  "readme": "README.md",
  "plugin": [],
  "theme": "default",
  "navigation": {
    "includeCategories": true,
    "includeGroups": true
  },
  "visibilityFilters": {
    "protected": false,
    "private": false,
    "inherited": true,
    "external": false
  }
}