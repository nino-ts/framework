{
    "compilerOptions": {
        "declaration": true,
        "declarationMap": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "module": "ESNext",
        "moduleResolution": "bundler",
        "allowImportingTsExtensions": false,
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "sourceMap": true,
        "strict": true,
        "noImplicitAny": true,
        "target": "ESNext"
    },
    "exclude": ["node_modules"],
    "include": ["src/**/*.ts", "tests/**/*.ts"]
}
