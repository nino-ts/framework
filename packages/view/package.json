{
    "author": "Ninots Framework",
    "description": "HTML/TSX view rendering with safe escaping for Bun",
    "devDependencies": {
        "@types/bun": "catalog:"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./index.ts",
            "default": "./index.ts"
        },
        "./jsx-runtime": {
            "types": "./dist/src/jsx-runtime.d.ts",
            "import": "./src/jsx-runtime.ts",
            "default": "./src/jsx-runtime.ts"
        },
        "./jsx-dev-runtime": {
            "types": "./dist/src/jsx-runtime.d.ts",
            "import": "./src/jsx-runtime.ts",
            "default": "./src/jsx-runtime.ts"
        }
    },
    "files": [
        "dist",
        "src"
    ],
    "keywords": [
        "bun",
        "html",
        "tsx",
        "views",
        "templates",
        "typescript"
    ],
    "license": "MIT",
    "name": "@ninots/view",
    "peerDependencies": {
        "typescript": "catalog:"
    },
    "scripts": {
        "test": "bun test",
        "typecheck": "tsc --noEmit"
    },
    "type": "module",
    "version": "0.10.0",
    "types": "./dist/index.d.ts"
}
