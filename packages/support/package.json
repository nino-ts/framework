{
    "author": "Ninots Framework",
    "description": "String, Array, and Collection utility classes for Bun",
    "devDependencies": {
        "@types/bun": "catalog:"
    },
    "exports": {
        ".": {
            "types": "./dist/src/index.d.ts",
            "import": "./src/index.ts",
            "default": "./src/index.ts"
        },
        "./arr": {
            "types": "./dist/src/arr.d.ts",
            "import": "./src/arr.ts",
            "default": "./src/arr.ts"
        },
        "./collection": {
            "types": "./dist/src/collection.d.ts",
            "import": "./src/collection.ts",
            "default": "./src/collection.ts"
        },
        "./str": {
            "types": "./dist/src/str/str.d.ts",
            "import": "./src/str/str.ts",
            "default": "./src/str/str.ts"
        }
    },
    "files": [
        "dist",
        "src"
    ],
    "keywords": [
        "bun",
        "strings",
        "arrays",
        "collections",
        "helpers",
        "utilities",
        "typescript"
    ],
    "license": "MIT",
    "name": "@ninots/support",
    "peerDependencies": {
        "typescript": "catalog:"
    },
    "scripts": {
        "test": "bun test",
        "typecheck": "tsc --noEmit"
    },
    "type": "module",
    "version": "0.6.1",
    "types": "./dist/src/index.d.ts"
}
