{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "lib": [
            "ESNext",
            "ESNext.Disposable"
        ],
        "experimentalDecorators": false,
        "strict": true,
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "./src/*"
            ],
            "@/Types": [
                "./src/Types"
            ],
            "@/Exceptions": [
                "./src/Exceptions"
            ],
            "@/Relations/*": [
                "./src/Relations/*"
            ],
            "@/Concerns/*": [
                "./src/Concerns/*"
            ],
            "@/Decorators/*": [
                "./src/Decorators/*"
            ],
            "@/Scopes/*": [
                "./src/Scopes/*"
            ]
        }
    }
}