{
    "author": "Ninots Framework",
    "description": "Eloquent-like ORM for Bun built with native features - Standalone package",
    "devDependencies": {
        "@types/bun": "catalog:"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./index.ts",
            "default": "./index.ts"
        },
        "./casts": {
            "types": "./dist/src/casts/cast-registry.d.ts",
            "import": "./src/casts/cast-registry.ts",
            "default": "./src/casts/cast-registry.ts"
        },
        "./collection": {
            "types": "./dist/src/collection.d.ts",
            "import": "./src/collection.ts",
            "default": "./src/collection.ts"
        },
        "./model": {
            "types": "./dist/src/model.d.ts",
            "import": "./src/model.ts",
            "default": "./src/model.ts"
        },
        "./query-builder": {
            "types": "./dist/src/query-builder.d.ts",
            "import": "./src/query-builder.ts",
            "default": "./src/query-builder.ts"
        },
        "./relations": {
            "types": "./dist/src/relations/relation.d.ts",
            "import": "./src/relations/relation.ts",
            "default": "./src/relations/relation.ts"
        },
        "./types": {
            "types": "./dist/src/types.d.ts",
            "import": "./src/types.ts",
            "default": "./src/types.ts"
        }
    },
    "files": [
        "dist",
        "src",
        "index.ts"
    ],
    "keywords": [
        "bun",
        "orm",
        "eloquent",
        "database",
        "sql",
        "typescript",
        "standalone"
    ],
    "license": "MIT",
    "name": "@ninots/orm",
    "peerDependencies": {
        "typescript": "catalog:"
    },
    "scripts": {
        "build": "bun build index.ts --outdir dist --target bun",
        "format": "bun run biome format --write",
        "lint": "bun run biome lint",
        "test": "bun test",
        "test:db": "bun run scripts/test-with-db.ts",
        "type-check": "tsc --noEmit"
    },
    "type": "module",
    "version": "0.8.0",
    "types": "./dist/index.d.ts"
}
