{
  "$schema": "https://typedoc.org/schema.json",
  "categorizeByGroup": true,
  "categoryOrder": ["Models", "Query Builder", "Relations", "Casts", "Collection", "Utilities", "API"],
  "defaultCategory": "API",
  "entryPoints": ["./index.ts"],
  "exclude": ["**/*.test.ts", "**/tests/**"],
  "excludeExternals": true,
  "excludePrivate": true,
  "excludeProtected": true,
  "includeVersion": true,
  "name": "@ninots/orm API Documentation",
  "navigation": {
    "includeCategories": true,
    "includeGroups": true
  },
  "out": "./docs",
  "plugin": [],
  "readme": "./README.md",
  "theme": "default",
  "tsconfig": "./tsconfig.json",
  "visibilityFilters": {
    "inherited": true,
    "private": false,
    "protected": false
  }
}
