{
    "$schema": "https://jsr.io/schema/config-file.v1.json",
    "name": "@ninots/framework",
    "version": "0.4.0",
    "license": "MIT",
    "exports": "./dist/index.js",
    "publish": {
        "include": [
            "dist/**/*.js",
            "dist/**/*.d.ts",
            "LICENSE",
            "README.md"
        ],
        "exclude": [
            "dist/**/*.map",
            ".github/**",
            "packages/**",
            "scripts/**",
            "tests/**",
            "**/*.test.ts",
            "**/*.spec.ts"
        ]
    }
}
